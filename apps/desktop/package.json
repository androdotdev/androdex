{
    "name": "@androdex/desktop",
    "private": true,
    "author": "androdotdev",
    "description": "The GUI desktop app for opencode",
    "version": "0.1.0",
    "type": "module",
    "main": "dist/main/index.js",
    "scripts": {
        "dev": "concurrently \"vite\" \"pnpm exec tsc -p tsconfig.main.json --watch\" \"wait-on tcp:5173 && wait-on dist/main/index.js && nodemon --watch dist/main --watch dist/preload --ext js --exec electron .\"",
        "build:renderer": "vite build",
        "build:main": "tsc -p tsconfig.main.json",
        "build": "pnpm build:renderer && pnpm build:main && electron-builder",
        "preview": "electron ."
    },
    "devDependencies": {
        "@tailwindcss/vite": "catalog:",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "catalog:",
        "concurrently": "^10.0.3",
        "electron": "^39.0.0",
        "electron-builder": "^25.0.0",
        "nodemon": "^3.1.14",
        "tailwindcss": "catalog:",
        "typescript": "catalog:",
        "vite": "catalog:",
        "wait-on": "^8.0.0"
    },
    "dependencies": {
        "@androdex/server": "workspace:*",
        "@tabler/icons-react": "^3.44.0",
        "@xterm/addon-fit": "^0.11.0",
        "@xterm/xterm": "^6.0.0",
        "node-pty": "^1.1.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "zustand": "catalog:"
    }
}
